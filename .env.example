# ─── Google Sheets ────────────────────────────────────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Base64-encoded service account JSON key.
# Generate in Google Cloud Console → IAM → Service Accounts → Keys → JSON
# Then encode: base64 -i your-key.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=your_base64_encoded_key_here

# ─── Auth (NextAuth / Google OAuth) ───────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Your deployed Vercel URL (or http://localhost:3000 for dev)
NEXTAUTH_URL=http://localhost:3000

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of Google emails that have admin access
ADMIN_EMAILS=admin@yourcompany.com,warehouse.manager@yourcompany.com

# Passphrase for admin panel access (hashed check happens server-side)
ADMIN_PASSPHRASE=choose_a_strong_passphrase
